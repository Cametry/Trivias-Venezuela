{
  "expo": {
    "name": "Trivias Venezuela",
    "slug": "trivias-venezuela",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/logo de trivias.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo de trivias.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trivias.venezuela",
      "infoPlist": {
        "UIStatusBarHidden": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo de trivias.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.trivias.venezuela"
    },
    "androidStatusBar": {
      "hidden": true
    },
    "androidNavigationBar": {
      "visible": "immersive"
    },
    "web": {
      "favicon": "./assets/logo de trivias.png",
      "bundler": "metro",
      "name": "Trivias Venezuela"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "5a59a9f8-26b1-437b-bc79-f9d6b89b1d24"
      }
    }
  }
}
